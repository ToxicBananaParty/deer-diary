# =============================================================================
# Workspace root .gitignore — MC Stuff
# Per-subproject .gitignores (e.g. prism-to-modrinth-sync/.gitignore,
# Custom Mods/src/trmt-neoforge-1.21.1/.gitignore) layer on top of this.
# =============================================================================

# --- Prism instance symlink (huge, lives outside the workspace) ---
/Deer Diary

# --- Python: prism-to-modrinth-sync tool ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# --- prism-to-modrinth-sync transient outputs ---
prism-to-modrinth-sync/dist/
prism-to-modrinth-sync/build/
prism-to-modrinth-sync/.cache/
prism-to-modrinth-sync/*.mrpack

# --- Secrets — never commit ---
prism-to-modrinth-sync/config.local.toml
.env

# --- Server configs known to contain secrets ---
# The live BloomHost server has the canonical copy. preserve_globs in the
# server pack means packwiz-installer never overwrites the player-side
# (BloomHost-side) file regardless of what's in the published index, so
# omitting it from the repo is safe.
# bootstrap_deny_paths in [packwiz_server.deploy] also blocks re-pulling.
Custom Mods/server/config/Discord-Integration.toml

# --- prism-to-modrinth-sync one-off diagnostics ---
prism-to-modrinth-sync/diagnose.py
prism-to-modrinth-sync/promote.py

# --- Gradle / Java build cruft inside Custom Mods/src/* ---
Custom Mods/src/*/build/
Custom Mods/src/*/claude-reference/
Custom Mods/src/*/.gradle/
Custom Mods/src/*/bin/
Custom Mods/src/*/out/
Custom Mods/src/*/classes/
Custom Mods/src/*/run/
Custom Mods/src/*/.idea/
Custom Mods/src/*/.vscode/
Custom Mods/src/*/.settings/
Custom Mods/src/*/*.iml
Custom Mods/src/*/*.ipr
Custom Mods/src/*/*.iws
Custom Mods/src/*/.classpath
Custom Mods/src/*/.project
Custom Mods/src/*/hs_err_*.log
Custom Mods/src/*/replay_*.log
Custom Mods/src/*/*.hprof
Custom Mods/src/*/*.jfr

# --- Dev/agent files inside Custom Mods/src/* ---
Custom Mods/src/*/.claude/
Custom Mods/src/*/.cursor/
Custom Mods/src/*/AGENTS.md
Custom Mods/src/*/CLAUDE.md
Custom Mods/src/*/LEARNINGS.md

# --- External mod sources kept locally as reference, not redistributed ---
# (FTB Essentials + Library, used only as architectural reference when
# implementing deer-diary-commands. Out of caution we don't republish them.)
Custom Mods/src/FTB-Essentials-*/
Custom Mods/src/FTB-Library-*/
# Tom's Simple Storage — cloned only as reference while authoring Mixin
# patches in deer-diary-patches. Upstream MIT, but we don't republish.
Custom Mods/src/Toms-Storage/
# Per-mod "claude-reference/" dumps — full upstream repos dropped in for the
# agent to read while porting/patching (e.g. Sodium source under nvidium).
# Reference only, never redistributed.
Custom Mods/src/*/claude-reference/

# --- OS noise ---
.DS_Store
Thumbs.db
