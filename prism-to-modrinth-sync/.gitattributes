# Normalize all text files to LF in the repository. Windows checkouts get
# CRLF automatically via core.autocrlf=true; WSL/Linux/macOS get LF.
* text=auto eol=lf

# Explicit types (clearer when reading diffs / blame).
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary artifacts — never touched by line-ending conversion.
*.mrpack binary
*.jar binary
*.zip binary
*.png binary
